/// \enum	eCliConsts_t
/// \brief	Constants that define the default values of cli manager
typedef enum
{    
	kCliBufferSize 		    = 768,  ///< cli buffer size for transmission
	kDmaBufferSize          = 256,
	kHistoryCmdCount 		= 16,   ///< Number of commands to keep in backlog history
	kCliMaxUserData			= 64,   ///< Maximum number of items in userdata for asynchronous commands
} eCliConsts_t;

/// \enum	eLoginState_t
/// \brief	Login State to validate progression of login stages
typedef enum
{
	kLoginStage_NotLogged = 0,      ///< User is not logged in
	kLoginStage_UserPrompt,         ///< User prompt is shown
	kLoginStage_PasswordPrompt,     ///< Password prompt is shown
	kLoginStage_LoggedIn,           ///< User is logged in (provided a correct user and password combination)
} eLoginState_t;

/// \enum	eLoginAccess_t
/// \brief	Type of user access
typedef enum
{
	kLoginAccess_User = 0,          ///< Normal user access rights
	kLoginAccess_Factory,           ///< Factory privileged user access rights
} eLoginAccess_t;

/*******************************************************************************
*                               Structs
*******************************************************************************/
/// \struct	oCliFnc_t
/// \brief	Command-Line Function Descriptor
typedef struct 
{
	const char* szCmd;      ///< Zero-Terminated string command
	const char* szDesc;     ///< Zero-Terminated string command description
	int 		nCmdLen;    ///< Length of szCmd
	bool(*Exec)(int cmdId, const char* szCmdLine, int cmdLen, int len, int tokenCount); ///< Callback function that executes the command
} oCliFnc_t;

/// \struct	oCmdAsync_t
/// \brief	Asynchronous Command Descriptor
typedef struct
{
	int32_t		nFncId;		                    ///< Function ID of the asynchronous command; -1 when not executing async command.
	int32_t		nUserData[kCliMaxUserData];     ///< UserData of the asynchronous descriptor
    char        szUserData[kCliMaxUserData];    ///< String-type user data
} oCmdAsync_t;

/// \struct	oCliVar_t
/// \brief	System variable descriptor
typedef struct
{
	const char* szName;                         ///< Name of this command-line system variable
    const char* szDesc;                         ///< Description of this variable
	bool(*Get)(char* szArgument, char* szValue, int bufLen);      ///< Get callback of this command-line system variable
	bool(*Set)(char* szValue);                  ///< Set callback of this command-line system variable
} oCliVar_t;

/// \struct	oCmdLine_t
/// \brief	String representation of the command line
typedef struct
{
	char sz[kCliBufferSize];
} oCmdLine_t;

extern struct mallinfo __iar_dlmallinfo();      ///< Memory information function

#define MALLINFO_FIELD_TYPE size_t
/// \struct	mallinfo
/// \brief	Internal IAR Allocator information descriptor
struct mallinfo 
{
    MALLINFO_FIELD_TYPE arena;    ///< non-mmapped space allocated from system
    MALLINFO_FIELD_TYPE ordblks;  ///< number of free chunks
    MALLINFO_FIELD_TYPE smblks;   ///< always 0
    MALLINFO_FIELD_TYPE hblks;    ///< always 0
    MALLINFO_FIELD_TYPE hblkhd;   ///< space in mmapped regions
    MALLINFO_FIELD_TYPE usmblks;  ///< maximum total allocated space
    MALLINFO_FIELD_TYPE fsmblks;  ///< always 0
    MALLINFO_FIELD_TYPE uordblks; ///< total allocated space
    MALLINFO_FIELD_TYPE fordblks; ///< total free space
    MALLINFO_FIELD_TYPE keepcost; ///< releasable (via malloc_trim) space
};

