extern RTC_HandleTypeDef hrtc;
/// \brief		Cli_SetDate()
/// \details	Set the realtime clock date
///
/// \private
/// \param[in]  szValue     Date string YYYY/MM/DD
/// \return	    bool        Success
bool Cli_SetDate(char* szValue)
{
    if (szValue == NULL)
    {
        return false;
    }

	RTC_DateTypeDef oDate;
	memset(&oDate, 0, sizeof(RTC_TimeTypeDef));

	int len     = strlen(szValue);
	int idxSep  = 0;
	int lastIdx = 0;
	for (int a = 0; a < len; ++a)
	{
		if (szValue[a] == '-' || szValue[a] == '/' || (a == len-1))
		{
			if (a != len-1)
			{
				szValue[a] = '\0';
			}

			switch (idxSep)
			{
			case 0:
				oDate.Year = strtol(&szValue[lastIdx], NULL, 10) + 2000;
				break;
			case 1:
				oDate.Month = strtol(&szValue[lastIdx], NULL, 10);
				break;
			case 2:
				oDate.Date = strtol(&szValue[lastIdx], NULL, 10);
				break;
			default:
				break;
			};
			++idxSep;
			lastIdx = a+1;
		}
	}

	return (HAL_RTC_SetDate(&hrtc, &oDate, FORMAT_BIN) == HAL_OK);
}

/// \brief		Cli_GetDate()
/// \details	Get the realtime clock date
///
/// \private
/// \param[in]  szArgument  Optional parameters
/// \param[in]  szValue     Date string YYYY/MM/DD
/// \param[in]  bufLen      Maximum size of szValue
/// \return	    bool        Success
bool Cli_GetDate(char* szArgument, char* szValue, int bufLen)
{
    if (szValue == NULL)
    {
        return false;
    }

	RTC_DateTypeDef oDate;

	// Get the RTC current Date
	if (HAL_RTC_GetDate(&hrtc, &oDate, FORMAT_BIN) == HAL_OK)
    {
        return (snprintf(szValue, bufLen, "%04d/%02d/%02d\r\n", oDate.Year+2000, oDate.Month, oDate.Date) > 0);
    }
    return false;
}

/// \brief		Cli_SetTime()
/// \details	Set the realtime clock time
///
/// \private
/// \param[in]  szValue     Date string HH:MM:SS
/// \return	    bool        Success
bool Cli_SetTime(char* szValue)
{
    if (szValue == NULL)
    {
        return false;
    }

	RTC_TimeTypeDef oTime;
	memset(&oTime, 0, sizeof(RTC_TimeTypeDef));

	int len     = strlen(szValue);
	int idxSep  = 0;
	int lastIdx = 0;
	for (int a = 0; a < len; ++a)
	{
		if (szValue[a] == ':' || (a == len-1))
		{
			szValue[a] = '\0';
			switch (idxSep)
			{
			case 0:
				oTime.Hours = strtol(&szValue[lastIdx], NULL, 0);
				break;
			case 1:
				oTime.Minutes = strtol(&szValue[lastIdx], NULL, 0);
				break;
			case 2:
				oTime.Seconds = strtol(&szValue[lastIdx], NULL, 0);
				break;
			default:
				break;
			};
			++idxSep;
			lastIdx = a+1;
		}
	}

	return (HAL_RTC_SetTime(&hrtc, &oTime, FORMAT_BIN) == HAL_OK);
}

/// \brief		Cli_GetTime()
/// \details	Get the realtime clock time
///
/// \private
/// \param[in]  szArgument  Optional parameters
/// \param[in]  szValue     Time string HH:MM:SS
/// \param[in]  bufLen      Maximum size of szValue
/// \return	    bool        Success
bool Cli_GetTime(char* szArgument, char* szValue, int bufLen)
{
    if (szValue == NULL)
    {
        return false;
    }

	RTC_DateTypeDef oDate;
	RTC_TimeTypeDef oTime;

	// Get the RTC current Time
	// You MUST call GetDate AFTER GetTime to unlock variables of time descriptor
    if (HAL_RTC_GetTime(&hrtc, &oTime, FORMAT_BIN) == HAL_OK &&
        HAL_RTC_GetDate(&hrtc, &oDate, FORMAT_BIN) == HAL_OK)
    {
        // Display time Format : hh:mm:ss
        return snprintf(szValue, bufLen, "%02d:%02d:%02d\r\n", oTime.Hours, oTime.Minutes, oTime.Seconds) > 0;
    }
    return false;
}
